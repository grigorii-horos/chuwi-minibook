+/**
+ * goodix_i2c_read_quiet - read data from i2c without logging errors
+ *
+ * @client: i2c device.
+ * @reg: register to read from.
+ * @buf: buffer to store the read data.
+ * @len: length of data to read.
+ */
+static int goodix_i2c_read_quiet(struct i2c_client *client, u16 reg, u8 *buf, int len)
+{
+	struct i2c_msg msgs[2];
+	__be16 wbuf = cpu_to_be16(reg);
+	int ret;
+
+	msgs[0].flags = 0; msgs[0].addr = client->addr; msgs[0].len = 2; msgs[0].buf = (u8 *)&wbuf;
+	msgs[1].flags = I2C_M_RD; msgs[1].addr = client->addr; msgs[1].len = len; msgs[1].buf = buf;
+
+	ret = i2c_transfer(client->adapter, msgs, 2);
+	return (ret == ARRAY_SIZE(msgs) ? 0 : -EIO);
+}
